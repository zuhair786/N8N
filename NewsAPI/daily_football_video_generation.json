              "value": "Bearer YOUR_RUNWAY_API_KEY"
            }
          ]
        },
        "options": {}
      },
      "id": "64f1b356-97d0-4f7b-b6d7-ecd6db5c56f7",
      "name": "Poll Video Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2544,
        400
      ]
    },
    {
      "parameters": {
        "content": "## Setup Instructions\n\nReplace the following placeholder values with your actual API keys:\n\n1. **YOUR_NEWSAPI_KEY** - Get from https://newsapi.org/register\n2. **YOUR_OPENAI_API_KEY** - Get from https://platform.openai.com/api-keys\n3. **YOUR_PEXELS_API_KEY** - Get from https://www.pexels.com/api/new/\n4. **YOUR_RUNWAY_API_KEY** - Get from https://dev.runwayml.com/\n\n### Workflow Summary\n- Triggers daily at 12:00 PM (noon)\n- Fetches top 5 football news headlines\n- Uses GPT-4o to generate a video prompt + image search queries\n- Fetches relevant stock images from Pexels\n- Sends prompt + images to Runway ML for video generation\n- Polls Runway for completion after 60s",
        "height": 380,
        "width": 500
      },
      "id": "0b935901-020d-4e6b-bcd3-5b02d8501c5f",
      "name": "Sticky Note",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -48,
        -64
      ]
    }
  ],
